# --- Actual Budget Configuration ---
ACTUAL_SERVER_URL=https://actual.your-domain.com
ACTUAL_PASSWORD=your_password_here
ACTUAL_BUDGET_ID=your_budget_id_here

# --- AI Configuration (Ollama / Mistral-Nemo) ---
# Use 'openai' provider to leverage Ollama's v1 compatibility
LLM_PROVIDER=openai
AI_MODEL=mistral-nemo
OPENAI_BASE_URL=https://ollama.your-domain.com
OPENAI_API_KEY=ollama

# --- Automation Settings ---
# How often to check for transactions (Standard CRON format)
CRON_SCHEDULE="0 * * * *"
NODE_TLS_REJECT_UNAUTHORIZED=0

# --- The "Minified" Prompt Template ---
# This single-line version prevents Mistral-Nemo from adding newlines and spaces
AI_PROMPT="Categorize: {{payee}} ({{amount}}). Categories: {{#each categoryGroups}}{{#each categories}} {{id}} ({{name}}), {{/each}}{{/each}} Return ONLY minified JSON on one line: {\"type\": \"existing\", \"categoryId\": \"ID\"}"

# --- Feature Flags ---
# Set to true to run immediately when the container starts
CLASSIFY_ON_STARTUP=true
